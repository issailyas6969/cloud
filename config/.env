# ─────────────────────────────────────────────────────────────
# ec2-langgraph-deployer — environment config
# Load with: export $(cat .env | xargs)
# ─────────────────────────────────────────────────────────────

# GitHub webhook secret (must match what you set on GitHub)
GITHUB_WEBHOOK_SECRET=1234

# Branch to auto-deploy (pushes to other branches are ignored)
DEPLOY_BRANCH=main

# Webhook server port
WEBHOOK_PORT=8000

# ── GitHub repo ────────────────────────────────────────────────
REPO_CLONE_URL=https://github.com/issailyas6969/cloud.git
LOCAL_REPO_DIR=/tmp/deploy_repo

# ── AWS EC2 ────────────────────────────────────────────────────
EC2_HOST=44.204.73.181
EC2_USER=ubuntu
EC2_KEY_PATH=~/.ssh/cl.pem

# Where the app lives on the EC2 instance
APP_DIR=/home/ubuntu/cloudapp

# Command to restart the app after deploy
RESTART_CMD=sudo systemctl restart cloudapp